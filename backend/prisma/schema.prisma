generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String       @id @default(uuid())
  name        String
  createdAt   DateTime     @default(now())
  assessments Assessment[]
  companies   Company[]
  users       User[]
}

model User {
  id             String              @id @default(uuid())
  email          String              @unique
  password       String
  name           String
  role           String              @default("STUDENT")
  tenantId       String
  createdAt      DateTime            @default(now())
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  companyAccess  UserCompanyAccess[]
}

model Company {
  id           String              @id @default(uuid())
  name         String
  legalId      String?
  sector       String?
  size         String?
  contactEmail String?
  contactPhone String?
  address      String?
  city         String?
  status       String              @default("Activo")
  tenantId     String
  createdAt    DateTime            @default(now())
  answers      Answer[]
  surveyLinks  SurveyLink[]
  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  userAccess   UserCompanyAccess[]
}

model Assessment {
  id        String      @id @default(uuid())
  title     String
  tenantId  String
  courseId  String?
  questions Json
  createdAt DateTime    @default(now())
  answers   Answer[]
  course    Course?     @relation(fields: [courseId], references: [id])
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  diagnoses Diagnosis[]
}

model Course {
  id          String       @id @default(uuid())
  name        String
  createdAt   DateTime     @default(now())
  assessments Assessment[]
}

model Answer {
  id                 String     @id @default(uuid())
  assessmentId       String
  studentName        String
  studentEmail       String
  respondentName     String?
  respondentPosition String?
  respondentEmail    String?
  responses          Json
  submittedAt        DateTime   @default(now())
  companyId          String?
  assessment         Assessment @relation(fields: [assessmentId], references: [id])
  company            Company?   @relation(fields: [companyId], references: [id])
  diagnosis          Diagnosis?
}

model Diagnosis {
  id           String     @id @default(uuid())
  assessmentId String
  studentEmail String
  answerId     String?    @unique
  result       String
  score        Float?
  createdAt    DateTime   @default(now())
  answer       Answer?    @relation(fields: [answerId], references: [id])
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  reports      Report[]
}

model Report {
  id          String    @id @default(uuid())
  diagnosisId String
  content     String
  createdAt   DateTime  @default(now())
  diagnosis   Diagnosis @relation(fields: [diagnosisId], references: [id])
}

model SurveyLink {
  id           String    @id @default(uuid())
  token        String    @unique
  companyId    String
  assessmentId String
  createdBy    String
  expiresAt    DateTime?
  maxResponses Int?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([companyId])
}

model UserCompanyAccess {
  id               String   @id @default(uuid())
  userId           String
  companyId        String
  canSurvey        Boolean  @default(true)
  canViewReports   Boolean  @default(true)
  canRunQueries    Boolean  @default(false)
  grantedAt        DateTime @default(now())
  grantedBy        String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}
